{
  "name": "yuque-open-cli",
  "version": "1.1.0",
  "description": "Command-line interface for Yuque (语雀) — browse, edit, and manage your knowledge base from the terminal",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "yuque": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/bin.js",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test:ci && npm run build && npm run smoke:dist:built && npm run test:e2e:built",
    "dev": "tsx src/bin.ts",
    "smoke:dist": "npm run build && npm run smoke:dist:built",
    "smoke:dist:built": "node scripts/smoke-dist-cli.js",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:e2e": "npm run build && npm run test:e2e:built",
    "test:e2e:built": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.js\" \"*.config.ts\" \"*.config.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.js\" \"*.config.ts\" \"*.config.js\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "yuque",
    "cli",
    "knowledge-base",
    "markdown",
    "documentation"
  ],
  "author": "yuque",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuque/yuque-open-cli.git"
  },
  "bugs": {
    "url": "https://github.com/yuque/yuque-open-cli/issues"
  },
  "homepage": "https://github.com/yuque/yuque-open-cli#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.18.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
